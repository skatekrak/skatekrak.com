{
    "$schema": "https://turbo.build/schema.json",
    "globalPassThroughEnv": ["FNOX_AGE_KEY_FILE"],
    "tasks": {
        "build": {
            "dependsOn": ["^build"],
            "outputs": [".next/**", "!.next/cache/**", "dist", "node_modules/.prisma/**"],
            "passThroughEnv": [
                "NEXT_PUBLIC_KRAK_API_URL",
                "NEXT_PUBLIC_MAPBOX_ACCESS_TOKEN",
                "NEXT_PUBLIC_MEILI_HOST",
                "NEXT_PUBLIC_MEILI_API_KEY",
                "NEXT_PUBLIC_IMGPROXY_URL",
                "NEXT_PUBLIC_STAGE",
                "NEXT_PUBLIC_CARRELAGE_URL",
                "NEXT_PUBLIC_UMAMI_SCRIPT_URL",
                "NEXT_PUBLIC_UMAMI_WEBSITE_ID",
                "KRAK_API_URL"
            ]
        },
        "dev": {
            "persistent": true,
            "cache": false
        },
        "type-check": {}
    }
}
