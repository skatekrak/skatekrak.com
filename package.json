{
    "name": "@krak/monorepo",
    "dependencies": {
        "@manypkg/cli": "^0.21.4",
        "turbo": "^2.0.4"
    },
    "engines": {
        "node": "24",
        "bun": "1.3.10"
    },
    "packageManager": "bun@1.3.10",
    "private": false,
    "scripts": {
        "lint": "turbo lint && manypkg check",
        "build": "turbo build",
        "dev": "turbo dev --parallel",
        "dev:web": "turbo dev --filter=@krak/web",
        "dev:api": "turbo dev --filter=@krak/api",
        "dev:api:docker": "turbo dev:docker --filter=@krak/api",
        "build:api": "turbo build --filter=@krak/api",
        "build:carrelage": "turbo build --filter=@krak/carrelage",
        "start:api": "cd apps/api && bun run start",
        "start:carrelage": "turbo start --filter=@krak/carrelage"
    },
    "workspaces": [
        "apps/*",
        "packages/*"
    ],
    "trustedDependencies": [
        "core-js"
    ],
    "overrides": {
        "@types/react": "^19.2.14",
        "@types/react-dom": "^19.2.3"
    },
    "resolutions": {
        "@types/react": "^19.2.14",
        "@types/react-dom": "^19.2.3"
    },
    "devDependencies": {
        "@types/bun": "^1.3.9",
        "@types/node": "^25.3.0"
    }
}
