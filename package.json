{
    "name": "@krak/monorepo",
    "devDependencies": {
        "@types/bun": "^1.1.1",
        "@types/node": "^25.3.0",
        "oxlint": "^1.59.0",
        "turbo": "^2.0.4"
    },
    "engines": {
        "node": "24",
        "bun": "1.3.10"
    },
    "packageManager": "bun@1.3.10",
    "private": true,
    "scripts": {
        "lint": "oxlint . && bunx sherif",
        "build": "turbo build",
        "dev": "turbo dev --parallel --ui tui",
        "dev:web": "turbo dev --filter=@krak/web",
        "dev:manager": "turbo dev --filter=@krak/manager",
        "dev:api": "turbo dev --filter=@krak/api",
        "build:api": "turbo build --filter=@krak/api",
        "build:web": "turbo build --filter=@krak/web",
        "build:manager": "turbo build --filter=@krak/manager",
        "start:api": "cd apps/api && bun run start"
    },
    "workspaces": [
        "apps/*",
        "packages/*"
    ],
    "trustedDependencies": [
        "core-js"
    ],
    "overrides": {
        "@types/react": "^19.2.14",
        "@types/react-dom": "^19.2.3"
    },
    "resolutions": {
        "@types/react": "^19.2.14",
        "@types/react-dom": "^19.2.3"
    }
}
